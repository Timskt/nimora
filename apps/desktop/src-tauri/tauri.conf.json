{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AsterPet",
  "version": "0.1.0",
  "identifier": "dev.asterpet.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "control-center",
        "title": "AsterPet",
        "width": 1180,
        "height": 780,
        "minWidth": 720,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first extensible desktop companion",
    "longDescription": "AsterPet is a local-first desktop companion, automation runtime and creator platform."
  }
}
